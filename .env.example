# Aegis environment configuration
# Copy to .env and customize for local development

# Demo Patient Portal database
DATABASE_URL=postgresql://aegis:aegis_dev_password@localhost:5432/patient_portal

# MCP server port (Bob connects here)
MCP_PORT=8765

# JWT secret for demo Patient Portal (dev only — DO NOT use in production)
JWT_SECRET=dev-only-jwt-secret-change-me

# Aegis API (FastAPI) port for dashboard
AEGIS_API_PORT=8000

# Dashboard dev server
DASHBOARD_PORT=5173

# Demo Patient Portal port
PATIENT_PORTAL_PORT=3000
