# Aegis environment configuration
# Copy to .env and customize for local development

# Demo Patient Portal database
DATABASE_URL=postgresql://aegis:aegis_dev_password@localhost:5432/patient_portal

# MCP server port (Bob connects here)
MCP_PORT=8765

# JWT secret for demo Patient Portal (dev only — DO NOT use in production)
JWT_SECRET=dev-only-jwt-secret-change-me

# Aegis API (FastAPI) port for dashboard
AEGIS_API_PORT=8000

# Dashboard dev server
DASHBOARD_PORT=5173

# Demo Patient Portal port
PATIENT_PORTAL_PORT=3000

# --- Aegis API runtime configuration ---

# Absolute path to repo root. Leave unset locally to auto-detect from main.py
# location; Render sets this to /opt/render/project/src via render.yaml.
# AEGIS_REPO_ROOT=

# Path (relative to AEGIS_REPO_ROOT) that gets scanned on startup and via POST /api/scan.
AEGIS_SCAN_TARGET=demo/patient-portal

# Comma-separated CORS origins. Wildcard subdomains supported, e.g. https://*.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Uvicorn bind port. Render injects $PORT automatically.
PORT=8000

# Cooldown (seconds) between POST /api/scan requests per client IP.
RATE_LIMIT_SECONDS=60
